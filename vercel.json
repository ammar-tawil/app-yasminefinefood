{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/about-us",
      "destination": "/about",
      "permanent": true
    },
    {
      "source": "/about-us/",
      "destination": "/about",
      "permanent": true
    },
    {
      "source": "/contact-us",
      "destination": "/contact",
      "permanent": true
    },
    {
      "source": "/contact-us/",
      "destination": "/contact",
      "permanent": true
    },
    {
      "source": "/catalogue",
      "destination": "/products",
      "permanent": true
    },
    {
      "source": "/catalogue/",
      "destination": "/products",
      "permanent": true
    },
    {
      "source": "/home/form/sample-request",
      "destination": "/contact",
      "permanent": true
    },
    {
      "source": "/home/form/sample-request/",
      "destination": "/contact",
      "permanent": true
    },
    {
      "source": "/home/form/new-account-form",
      "destination": "/contact",
      "permanent": true
    },
    {
      "source": "/home/form/new-account-form/",
      "destination": "/contact",
      "permanent": true
    },
    {
      "source": "/home/form/:path*",
      "destination": "/contact",
      "permanent": true
    },
    {
      "source": "/products/pickles",
      "destination": "/products",
      "permanent": true
    },
    {
      "source": "/products/pickles/",
      "destination": "/products",
      "permanent": true
    },
    {
      "source": "/products/olive-oil",
      "destination": "/products",
      "permanent": true
    },
    {
      "source": "/products/olive-oil/",
      "destination": "/products",
      "permanent": true
    },
    {
      "source": "/products/dried-fruit",
      "destination": "/products",
      "permanent": true
    },
    {
      "source": "/products/dried-fruit/",
      "destination": "/products",
      "permanent": true
    },
    {
      "source": "/blog/:path*",
      "destination": "/about",
      "permanent": true
    },
    {
      "source": "/blog",
      "destination": "/about",
      "permanent": true
    },
    {
      "source": "/recipes/:path*",
      "destination": "/about",
      "permanent": true
    },
    {
      "source": "/recipes",
      "destination": "/about",
      "permanent": true
    },
    {
      "source": "/shop/:path*",
      "destination": "/products",
      "permanent": true
    },
    {
      "source": "/shop",
      "destination": "/products",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
