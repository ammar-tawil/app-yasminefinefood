{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/about-us/?",
      "destination": "/about",
      "permanent": true
    },
    {
      "source": "/contact-us/?",
      "destination": "/contact",
      "permanent": true
    },
    {
      "source": "/products/?",
      "destination": "/products",
      "permanent": true
    },
    {
      "source": "/catalogue/?",
      "destination": "/products",
      "permanent": true
    },
    {
      "source": "/home/form/sample-request/?",
      "destination": "/contact",
      "permanent": true
    },
    {
      "source": "/home/form/new-account-form/?",
      "destination": "/contact",
      "permanent": true
    },
    {
      "source": "/products/pickles/?",
      "destination": "/products/pickles",
      "permanent": true
    },
    {
      "source": "/products/olive-oil/?",
      "destination": "/products/olive-oil",
      "permanent": true
    },
    {
      "source": "/products/dried-fruit/?",
      "destination": "/products/dried-fruit",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
